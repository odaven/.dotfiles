#!/usr/bin/env zsh

# Define a mapping of configurations
declare -A CONFIGS=(
  [rust]="setup_rust"
  [tmux]="setup_tmux"
  [vim]="setup_vim"
  [zsh]="setup_zsh"
)

setup_rust() {
  rustup default stable
}

setup_tmux() {
  # Just in case already exist
  rm -rf "$HOME"/.dotfiles/config/tmux/plugins
  git clone https://github.com/tmux-plugins/tpm "$HOME"/.dotfiles/config/tmux/plugins/tpm

  ln -sfv "$HOME"/.dotfiles/config/tmux "$HOME"/.config

  ~/.config/tmux/plugins/tpm/bin/install_plugins
}

setup_vim() {
  ln -sfv "$HOME"/.dotfiles/config/vim/.vimrc "$HOME"/.vimrc
  curl -fLo "$HOME"/.vim/autoload/plug.vim --create-dirs \
      https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
  vim +PlugInstall +qall
}

setup_zsh() {
  rm -rf "$HOME"/.config/oh-my-zsh/

  export KEEP_ZSHRC='yes'
  export ZSH="$HOME"/.config/oh-my-zsh
  curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh | bash

  [ -d "$HOME"/.config/zsh ] && rm -rf "$HOME"/.config/zsh
  ln -sfv "$HOME"/.dotfiles/config/zsh "$HOME"/.config

  ln -sfv "$HOME"/.config/zsh/.zshenv "$HOME"/.zshenv
}

# Run all tasks
run_all() {
  for key in "${(@k)CONFIGS}"; do
    echo "Running setup for $key..."
    "${CONFIGS[$key]}"
  done
}

# Main logic
if [[ $# -eq 0 ]]; then
  cat <<EOF
Usage: dotfiles-setup <option>
Examples:
  dotfiles-setup -a                # Run all setup tasks (--all or -a)
  dotfiles-setup -l                # List available options (--list or -l)
  dotfiles-setup tmux              # Run only the Tmux setup
  dotfiles-setup tmux zsh          # Run Tmux and Zsh setups
EOF
  exit 1
fi

for option in "$@"; do
  if [[ "$option" == "--all" || "$option" == "-a" ]]; then
    echo "Running all setup tasks..."
    run_all
  elif [[ "$option" == "--list" || "$option" == "-l" ]]; then
    echo "Available options:"
    for key in "${(@k)CONFIGS}"; do
      echo "  $key"
    done
  elif [[ -n "${CONFIGS[$option]}" ]]; then
    echo "Running setup for $option..."
    "${CONFIGS[$option]}"
  else
    echo "Error: '$option' is not a valid option."
    exit 1
  fi
done
